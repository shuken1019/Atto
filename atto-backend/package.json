{
  "name": "atto-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "security:audit": "npm audit --audit-level=high",
    "security:zap:baseline": "docker run --rm -t -v $(pwd):/zap/wrk ghcr.io/zaproxy/zaproxy:stable zap-baseline.py -t http://localhost:4000/api/health -r /zap/wrk/zap-report.html"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mysql2": "^3.15.3"
  }
}
